package server.zone.objects.tangible.misc;

import server.zone.objects.tangible.TangibleObject;
import server.zone.objects.scene.SceneObject;
import server.zone.Zone;
import engine.lua.LuaObject;
import server.zone.packets.scene.AttributeListMessage;
import server.zone.objects.creature.CreatureObject;
import server.zone.ZoneServer;
include templates.SharedObjectTemplate;
import server.zone.packets.object.ObjectMenuResponse;
import server.zone.objects.tangible.misc.FsBuffItemDeathObserver;

@lua
@json
class FsBuffItem extends TangibleObject {
	protected unsigned int reuseTime;
	protected int buffAttribute;
	protected int buffValue;
	protected unsigned int buffDuration;
	protected int maxUses;
	protected int usesRemaining;
	protected FsBuffItemDeathObserver deathObserver;
	@weakReference
	protected CreatureObject activePlayer;

	public FsBuffItem() {
		setLoggingName("FsBuffItem");

		reuseTime = 60 * 60 * 1000; // 1 hour cooldown
		buffAttribute = 0; // Default health
		buffValue = 1000; // 1000 point default
		buffDuration = 24 * 60 * 60; // 24 hours protection duration
		maxUses = 5; // 5 uses default
		usesRemaining = 5; // Start with max uses
		deathObserver = null;
		activePlayer = null;
	}

	@local
	@dirty
	public native void fillAttributeList(AttributeListMessage msg, CreatureObject player);

	@preLocked
	@arg1preLocked
	public native int handleObjectMenuSelect(CreatureObject player, byte selectedID);

	@local
	@dirty
	public native void fillObjectMenuResponse(ObjectMenuResponse menuResponse, CreatureObject player);

	public native string getTimeString(unsigned int timestamp);

	public native unsigned int getBuffCRC();

	@preLocked
	public void setReuseTime(unsigned int time) {
		reuseTime = time;
	}

	@preLocked
	public void setBuffAttribute(int attrib) {
		buffAttribute = attrib;
	}

	@preLocked
	public void setBuffValue(int value) {
		buffValue = value;
	}

	@preLocked
	public void setBuffDuration(unsigned int dur) {
		buffDuration = dur;
	}

	@preLocked
	public void setMaxUses(int uses) {
		maxUses = uses;
		usesRemaining = uses;
	}

	@preLocked
	public void setUsesRemaining(int uses) {
		usesRemaining = uses;
	}

	@preLocked
	public native void decreaseUses();

	public int getUsesRemaining() {
		return usesRemaining;
	}

	public int getMaxUses() {
		return maxUses;
	}

	@preLocked
	public void setDeathObserver(FsBuffItemDeathObserver observer) {
		deathObserver = observer;
	}

	public FsBuffItemDeathObserver getDeathObserver() {
		return deathObserver;
	}

	@preLocked
	public void setActivePlayer(CreatureObject player) {
		activePlayer = player;
	}

	@dirty
	public native CreatureObject getActivePlayer();

	@preLocked
	public native void removeObserverFromPlayer();

	@preLocked
	public native void restoreObserverOnLogin(CreatureObject player);
}
